# ─────────────────────────────────────────────────────────────────────────────
# Toti Cakery Chatbot — environment variables
# Copy to `.env` and adjust. Everything tunable lives here (PROMPT rules #2/#4).
# ─────────────────────────────────────────────────────────────────────────────

# ── Service ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Backend (Nicholas's FastAPI) ──────────────────────────────────────────────
# Base URL only. Paths are resolved in code because the backend has a
# double-prefix routing bug — never hardcode raw paths. See README.
BACKEND_BASE_URL=http://localhost:8001
# If true, the client probes /openapi.json on startup to confirm real paths.
BACKEND_VERIFY_PATHS_VIA_OPENAPI=true
BACKEND_REQUEST_TIMEOUT_SECONDS=10
# Sent as X-Service-Key on backend calls. Must equal the backend's SERVICE_API_KEY.
BACKEND_SERVICE_API_KEY=your-secret-chatbot-key-here

# ── Ollama (LLM + embeddings) ─────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=qwen3:1.7b
EMBEDDING_MODEL=qwen3-embedding:0.6b
LLM_TEMPERATURE=0.7
LLM_TOP_P=0.8
LLM_NUM_CTX=32768
# qwen3 thinking mode. false = OFF (recommended for this small model).
LLM_REASONING=false

# ── RAG / ChromaDB ────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=toti_faq
KNOWLEDGE_BASE_DIR=./knowledge_base/faq
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=77
RAG_TOP_K=3
# Below this similarity (0..1), the bot refuses to answer (out-of-scope guard).
RAG_SIMILARITY_THRESHOLD=0.40

# ── WhatsApp gateway (wwebjs-api) ─────────────────────────────────────────────
WWEBJS_BASE_URL=http://wwebjs-api:3000
WWEBJS_API_KEY=change-me
WWEBJS_SESSION_ID=toti

# ── Local chatbot DB (SQLite) ─────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./toti_chatbot.db

# ── Payment gateway (MOCK Midtrans) ───────────────────────────────────────────
PAYMENT_GATEWAY_URL=http://payment-gateway:9000
PAYMENT_CHECK_INTERVAL_SECONDS=30
PAYMENT_TIMEOUT_MINUTES=30
ALLOW_DOWN_PAYMENT=true
DOWN_PAYMENT_PERCENTAGE=0.50

# ── Checkout / identity ───────────────────────────────────────────────────────
AUTOFILL_PHONE_FROM_WA=true

# ── Admin / human takeover ────────────────────────────────────────────────────
ADMIN_WA_NUMBER=628123456789
TAKEOVER_EXPIRY_DAYS=7

# ── Store info (for pickup/delivery messages) ─────────────────────────────────
STORE_NAME=Toti Cakery
STORE_ADDRESS=Jl. Contoh No. 123, Jakarta

# ── Owner gating (financial_report / business_analytics) ──────────────────────
# Comma-separated WA numbers allowed to query owner-only tools.
OWNER_WA_NUMBERS=628123456789
