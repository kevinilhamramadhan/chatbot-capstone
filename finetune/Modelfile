# Modelfile untuk model hasil fine-tune (toti-qwen).
# Konfigurasi TEMPLATE/RENDERER/PARSER + parameter disalin PERSIS dari
# `ollama show qwen3.5:0.8b --modelfile` (base memakai renderer bawaan Ollama,
# bukan Go-template — butuh Ollama >= 0.17.1).
# Pemakaian:
#   1. Taruh GGUF hasil Colab di folder ini dengan nama toti-qwen.Q8_0.gguf
#   2. ollama create toti-qwen -f Modelfile
FROM ./toti-qwen.Q8_0.gguf
TEMPLATE {{ .Prompt }}
RENDERER qwen3.5
PARSER qwen3.5
PARAMETER presence_penalty 1.5
PARAMETER temperature 1
PARAMETER top_k 20
PARAMETER top_p 0.95
